<?xml version="1.0" encoding="utf-8"?>
<!-- Custom expanded notification layout for step counter -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Stats grid: 2x2 layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <!-- Distance -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:id="@+id/ic_distance"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_stat_distance"
                android:layout_marginEnd="4dp" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_distance_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0 km"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quãng đường"
                    android:textSize="10sp"
                    android:textColor="#B0BEC5" />
            </LinearLayout>
        </LinearLayout>

        <!-- Calories -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:id="@+id/ic_calories"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_stat_calories"
                android:layout_marginEnd="4dp" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_calories_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 cal"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calo"
                    android:textSize="10sp"
                    android:textColor="#B0BEC5" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Row 2: Time + Goal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <!-- Time -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:id="@+id/ic_time"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_stat_time"
                android:layout_marginEnd="4dp" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_time_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 phút"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thời gian"
                    android:textSize="10sp"
                    android:textColor="#B0BEC5" />
            </LinearLayout>
        </LinearLayout>

        <!-- Goal -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:id="@+id/ic_goal"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_stat_goal"
                android:layout_marginEnd="4dp" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_goal_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mục tiêu"
                    android:textSize="10sp"
                    android:textColor="#B0BEC5" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@android:drawable/progress_horizontal"
        android:layout_marginBottom="4dp" />

    <!-- Motivation text -->
    <TextView
        android:id="@+id/tv_motivation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Đang theo dõi..."
        android:textSize="11sp"
        android:textStyle="italic"
        android:textColor="#90A4AE"
        android:gravity="center" />

</LinearLayout>
